@model Worktastic.Models.JobPosting
@{
    ViewData["Title"] = "Inseratformular";
}

<form asp-controller="JobPosting" asp-action="CreateEdit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <div class="card">
        <div class="card-header">
            <h4>Inserat eintragen / bearbeiten</h4>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col">
                    <input class="form-control" asp-for="JobTitle" type="text" placeholder="Bitte trage die Jobbezeichnung ein" />
                </div>
                <div class="col">
                    <input class="form-control" asp-for="JobLocation" type="text" placeholder="Bitte trage einen Ort ein" />
                </div>
            </div>
            <div class="row mb-3">
                <textarea class="form-control" asp-for="JobDescription" placeholder="Bitte Beschreibung eintragen"></textarea>
            </div>
            <div class="row mb-3">
                <div class="col">
                    <input class="form-control" asp-for="Salary" type="number" placeholder="Wie viel Jahresgehalt?" />
                </div>
                <div class="col">
                    <input class="form-control" asp-for="StartDate" type="date" />
                </div>
            </div>
            <hr />

            <div class="row mb-3">
                <div class="col">
                    <input class="form-control" asp-for="ContactName" type="text" placeholder="Wer?" />
                </div>
                <div class="col">
                    <input class="form-control" asp-for="ContactWebsite" type="url" placeholder="Website" />
                </div>
            </div>
            <div class="row mb-3">
                <div class="col">
                    <input class="form-control" asp-for="ContactEmail" type="email" placeholder="Email" />
                </div>
                <div class="col">
                    <input class="form-control" asp-for="ContactPhone" type="tel" placeholder="Telefon" />
                </div>
            </div>
            <div class="row">
                <label class="mb-1">Firmenlogo hochladen</label>
                <input type="file" name="CompanyLogo" class="form-control" />
            </div>
        </div>
        <div class="card-footer">
            <button class="btn btn-secondary" type="submit">Speichern</button>
        </div>
    </div>
</form>
