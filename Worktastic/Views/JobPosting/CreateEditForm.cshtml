@model Worktastic.Models.JobPosting
@{
    ViewData["Title"] = "Inseratformular";
}
<div class="container mt-5">
    <form asp-controller="JobPosting" asp-action="CreateEdit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />

        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-header">
                <h4>Inserat eintragen / bearbeiten</h4>
            </div>
            <div class="card-body">
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="JobTitle" class="form-label">Jobbezeichnung</label>
                        <input class="form-control form-control-lg" asp-for="JobTitle" type="text" placeholder="Bitte trage die Jobbezeichnung ein" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="JobLocation" class="form-label">Ort der Beschäftigung</label>
                        <input class="form-control form-control-lg" asp-for="JobLocation" type="text" placeholder="Bitte trage einen Ort ein" />
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="JobDescription" class="form-label">Job Beschreibung</label>
                    <textarea class="form-control form-control-lg" asp-for="JobDescription" placeholder="Bitte Beschreibung eintragen"></textarea>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Salary" class="form-label">Gehalt</label>
                        <input class="form-control form-control-lg" asp-for="Salary" type="number" placeholder="Wie viel Jahresgehalt?" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="StartDate" class="form-label">Start Datum</label>
                        <input class="form-control form-control-lg" asp-for="StartDate" type="date" />
                    </div>
                </div>
                <hr />

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="ContactName" class="form-label">Kontakt Name</label>
                        <input class="form-control form-control-lg" asp-for="ContactName" type="text" placeholder="Wer?" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ContactWebsite" class="form-label">Kontakt Webseite</label>
                        <input class="form-control form-control-lg" asp-for="ContactWebsite" type="url" placeholder="Website" />
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="ContactEmail" class="form-label">Kontakt Email</label>
                        <input class="form-control form-control-lg" asp-for="ContactEmail" type="email" placeholder="Email" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ContactPhone" class="form-label">Kontakt Telefon</label>
                        <input class="form-control form-control-lg" asp-for="ContactPhone" type="tel" placeholder="Telefon" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="mb-1">Firmenlogo hochladen</label>
                    <input type="file" name="CompanyLogo" class="form-control" />
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <button class="btn btn-primary btn-lg w-100" type="submit">Inserat speichern</button>
            </div>
        </div>
        </>
    </form>
</div>