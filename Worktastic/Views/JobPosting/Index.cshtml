@model List<JobPosting>
@{
    ViewData["Title"] = "Deine Inserate";
}

<a class="btn btn-success mb-3" asp-controller="JobPosting" asp-action="CreateEditForm">neues Inserat</a>
<hr class="mb-3 " />
<table id="AdminTabelle" class="table table-bordered table-striped table-hover">
    <thead>
        <tr>
            <th>Id</th>
            <th>Job Titel</th>
            <th>Ort</th>
            <th>Startdatum</th>
            <th>Aktionen</th>
        </tr>
    </thead>
    <tbody>
        @{
            foreach(JobPosting job in Model)
            {
                <tr>
                    <td>@job.Id</td>
                    <td>@job.JobTitle</td>
                    <td>@job.JobLocation</td>
                    <td>@job.StartDate.ToShortDateString()</td>
                    <td>
                        <a class="btn btn-warning" asp-route-id="@job.Id" asp-controller="JobPosting" asp-action="CreateEditForm">Edit</a>
                        <button class="btn btn-danger" onclick="deleteInserat(@job.Id)">Delete</button>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#AdminTabelle').DataTable();
        });


        function deleteInserat(jobPostingId) {
            Swal.fire({
                title: "Wollen Sie das Inserat wirklich löschen?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: "Ja, löschen",
                cancelButtonText: "Abbrechen"
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("Delete", "JobPosting")",
                        data: { id : jobPostingId },
                        success: function () {
                            Swal.fire("Inserat gelöscht", "", "success").then(() => {
                                location.reload();
                            });
                        },
                        error: function () {
                            Swal.fire("Ups, es ist was schiefgelaufen!", "", "error");
                        }
                    });      
                }
            });
        }

    </script>
        
}